# Admins who are allowed to CREATE and own leagues. Comma-separated email
# addresses. A user becomes an admin when they sign up (or sign in) with an
# email listed here. Add as many as you like.
# Example: you@example.com,friend@example.com
ADMIN_EMAILS=

# Public site URL used to build the email-confirmation redirect link. In local
# dev this is http://localhost:3000; in production set it to your real domain
# (also add the same URL under Supabase → Authentication → URL Configuration).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: protects the /api/cron/matchmaking endpoint. If set, the daily
# GitHub Action must send the same value (add it as a repo secret too).
CRON_SECRET=
