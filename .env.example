# Copy this file to .env.local and fill in real values from your Supabase project.
# https://supabase.com/dashboard/project/_/settings/api

# Public (safe to ship to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (never expose to the client). Used by server actions for
# pairing & bracket progression that need to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: comma-separated list of admin emails (currently unused, reserved
# for future moderation tooling).
ADMIN_EMAILS=
